{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake",
            "args": ["-S", ".", "-B", "build", "-DCMAKE_BUILD_TYPE=Release"],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake Build",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build", "--config", "Release", "-j4"],
            "group": { "kind": "build", "isDefault": true },
            "dependsOn": "CMake Configure",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run Neural Network",
            "type": "shell",
            "command": "./build/neural_network",
            "dependsOn": "CMake Build",
            "group": { "kind": "test", "isDefault": true },
            "problemMatcher": []
        }
    ]
}
